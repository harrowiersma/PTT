# openPTT one-click P50 provisioning -- Windows / PowerShell edition.
#
# Rendered per-device by server/api/provisioning.py. Do not edit the
# rendered copy; edit the template at provisioning/windows.ps1.tmpl and
# regenerate a token.
#
#   username        : {{username}}
#   admin URL       : {{admin_url}}
#   traccar URL     : {{traccar_url}}
#   mumble host:port: {{mumble_host}}:{{mumble_port}}
#   slug            : {{slug}}

$ErrorActionPreference = 'Stop'

$Username       = '{{username}}'
$MumblePassword = '{{mumble_password}}'
$AdminUrl       = '{{admin_url}}'
$TraccarUrl     = '{{traccar_url}}'
$MumbleHost     = '{{mumble_host}}'
$MumblePort     = '{{mumble_port}}'
$Slug           = '{{slug}}'

$Package  = 'ch.harro.openptt'
$Activity = "$Package/se.lublin.mumla.app.MumlaActivity"

$WorkDir = Join-Path $env:TEMP ("openptt-provision-" + [System.Guid]::NewGuid().ToString("N"))
New-Item -ItemType Directory -Path $WorkDir | Out-Null

function Step($msg)  { Write-Host "`n==> $msg" -ForegroundColor Cyan }
function Ok($msg)    { Write-Host "    OK  $msg" -ForegroundColor Green }
function Fail($msg, $cmd) {
    Write-Host "`n!!  $msg" -ForegroundColor Red
    if ($cmd) { Write-Host "    command: $cmd" -ForegroundColor Red }
    Write-Host "    Fix the issue above and rerun this script." -ForegroundColor Red
    exit 1
}

try {
    # 1. Preflight: adb.exe.
    Step "Checking adb.exe"
    $adb = Get-Command adb.exe -ErrorAction SilentlyContinue
    if (-not $adb) {
        Write-Host @"
adb.exe is not on PATH.

Install options:
  scoop install adb
  choco install adb
  Manual: https://developer.android.com/tools/releases/platform-tools
          then add the platform-tools folder to your PATH.

Install, open a new PowerShell window, then rerun this script.
"@ -ForegroundColor Red
        exit 1
    }
    Ok "adb found: $($adb.Source)"

    # 2. Exactly one device?
    Step "Detecting connected P50"
    $raw = & adb.exe devices
    $lines = $raw | Select-Object -Skip 1 | Where-Object { $_ -match '\sdevice$' }
    if (-not $lines -or $lines.Count -eq 0) {
        Fail "No device attached. Plug the P50 in via USB, confirm 'Allow USB debugging' on-screen, then rerun."
    }
    if ($lines.Count -gt 1) {
        Fail "$($lines.Count) devices connected. Unplug all but the target P50 and rerun."
    }
    $serial = ($lines[0] -split '\s+')[0]
    Ok "Device: $serial"

    # 3. Download APK.
    Step "Downloading APK"
    $apkUrl  = "$AdminUrl/apk/openptt-foss-debug.apk"
    $apkFile = Join-Path $WorkDir "openptt.apk"
    try {
        Invoke-WebRequest -Uri $apkUrl -OutFile $apkFile -UseBasicParsing
    } catch {
        Fail "APK download failed" "Invoke-WebRequest $apkUrl"
    }
    Ok "APK downloaded ($((Get-Item $apkFile).Length) bytes)"

    # 4. Install / upgrade.
    Step "Installing APK"
    & adb.exe -s $serial install -r $apkFile
    if ($LASTEXITCODE -ne 0) { Fail "adb install failed" "adb install -r openptt.apk" }
    Ok "APK installed"

    # 5. Runtime permissions.
    Step "Granting runtime permissions"
    $perms = @(
        'android.permission.RECORD_AUDIO',
        'android.permission.ACCESS_FINE_LOCATION',
        'android.permission.ACCESS_COARSE_LOCATION',
        'android.permission.POST_NOTIFICATIONS'
    )
    foreach ($p in $perms) {
        & adb.exe -s $serial shell pm grant $Package $p 2>$null
        if ($LASTEXITCODE -eq 0) {
            Ok "granted $p"
        } else {
            Write-Host "    (skipped $p -- may not apply to this Android version)"
        }
    }

    # 6. Seed SharedPreferences.
    Step "Seeding SharedPreferences"
    $prefsXml = Join-Path $WorkDir "prefs.xml"
    @"
<?xml version='1.0' encoding='utf-8' standalone='yes' ?>
<map>
    <string name="admin_url">$AdminUrl</string>
    <string name="traccar_url">$TraccarUrl</string>
    <boolean name="auto_connect" value="true" />
    <boolean name="lone_worker_enabled" value="false" />
    <string name="audioInputMethod">ptt</string>
</map>
"@ | Set-Content -Encoding UTF8 -NoNewline -Path $prefsXml

    & adb.exe -s $serial push $prefsXml "/data/local/tmp/openptt_prefs.xml" | Out-Null
    if ($LASTEXITCODE -ne 0) { Fail "push of prefs.xml failed" "adb push prefs.xml" }
    $cmd = "run-as $Package sh -c 'mkdir -p shared_prefs && cat /data/local/tmp/openptt_prefs.xml > shared_prefs/${Package}_preferences.xml'"
    & adb.exe -s $serial shell $cmd
    if ($LASTEXITCODE -ne 0) { Fail "seed of SharedPreferences failed" $cmd }
    & adb.exe -s $serial shell "rm /data/local/tmp/openptt_prefs.xml" 2>$null | Out-Null
    Ok "SharedPreferences seeded"

    # 7. Seed Humla mumble.db (sqlite3 required -- scoop install sqlite).
    Step "Seeding Humla server row"
    $sqlite = Get-Command sqlite3.exe -ErrorAction SilentlyContinue
    if (-not $sqlite) {
        Fail "sqlite3.exe not on PATH (install via 'scoop install sqlite' or 'choco install sqlite') and rerun."
    }
    $dbFile = Join-Path $WorkDir "mumble.db"
    $sql = @"
CREATE TABLE server (
    _id INTEGER PRIMARY KEY AUTOINCREMENT,
    name TEXT NOT NULL,
    host TEXT NOT NULL,
    port INTEGER,
    username TEXT NOT NULL,
    password TEXT
);
INSERT INTO server (name, host, port, username, password)
VALUES ('openPTT', '$MumbleHost', $MumblePort, '$Username', '$MumblePassword');
"@
    $sql | & sqlite3.exe $dbFile
    & adb.exe -s $serial push $dbFile "/data/local/tmp/openptt_mumble.db" | Out-Null
    if ($LASTEXITCODE -ne 0) { Fail "push of mumble.db failed" "adb push mumble.db" }
    $cmd = "run-as $Package sh -c 'mkdir -p databases && cat /data/local/tmp/openptt_mumble.db > databases/mumble.db'"
    & adb.exe -s $serial shell $cmd
    if ($LASTEXITCODE -ne 0) { Fail "seed of mumble.db failed" $cmd }
    & adb.exe -s $serial shell "rm /data/local/tmp/openptt_mumble.db" 2>$null | Out-Null
    Ok "Humla mumble.db seeded with server=$MumbleHost user=$Username"

    # 8. Launch app.
    Step "Launching openPTT"
    & adb.exe -s $serial shell am start -n $Activity | Out-Null
    if ($LASTEXITCODE -ne 0) { Fail "app launch failed" "adb shell am start -n $Activity" }
    Ok "openPTT started on device"

    # 9. Mark token used.
    Step "Reporting success to admin"
    try {
        Invoke-WebRequest -Uri "$AdminUrl/api/provisioning/tokens/$Slug/completed" -Method Post -UseBasicParsing | Out-Null
    } catch {
        Write-Host "    (could not reach admin -- token will stay un-marked, not fatal)"
    }

    Write-Host "`n==>  Device $serial provisioned for user $Username." -ForegroundColor Green
    Write-Host "    Mumble should auto-connect to ${MumbleHost}:${MumblePort} in a few seconds."
    Write-Host "    If it does not, verify USB debugging is still authorized and the device is online.`n"
} finally {
    if (Test-Path $WorkDir) {
        Remove-Item -Recurse -Force $WorkDir -ErrorAction SilentlyContinue
    }
}
