# PTT Admin Service Configuration
# Copy to .env and edit values

# Admin credentials (change these!)
PTT_ADMIN_USERNAME=admin
PTT_ADMIN_PASSWORD=changeme

# JWT secret (generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))")
PTT_SECRET_KEY=change-me-generate-a-real-secret

# Database (Docker Compose sets this automatically)
PTT_DATABASE_URL=postgresql+asyncpg://ptt:ptt@postgres:5432/ptt
PTT_DATABASE_URL_SYNC=postgresql+psycopg2://ptt:ptt@postgres:5432/ptt

# Murmur ICE connection
PTT_MURMUR_ICE_HOST=murmur
PTT_MURMUR_ICE_PORT=6502
PTT_MURMUR_ICE_SECRET=

# Public server address (used in QR codes for device enrollment)
# This is the voice subdomain that P50 devices connect to
PTT_PUBLIC_HOST=voice.harro.ch
PTT_PUBLIC_PORT=443

# Domain configuration
# Two DNS A records pointing to the same VPS IP:
#   ptt.harro.ch -> <VPS_IP>  (admin dashboard)
#   voice.harro.ch -> <VPS_IP>  (Mumble voice traffic)
# Nginx stream module routes port 443 by SNI (TLS hostname)
